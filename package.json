{
  "name": "visioryx",
  "private": true,
  "description": "Monorepo helper scripts — real apps live in frontend/, mobile/, backend/",
  "scripts": {
    "start:sim": "npm --prefix mobile run start:sim",
    "start:mobile:device": "npm --prefix mobile run start:device",
    "mobile:start": "npm --prefix mobile start",
    "mobile:start:clear": "npm --prefix mobile run start:clear",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:dev:clean": "npm --prefix frontend run dev:clean",
    "dev:all": "./start-dev.sh all"
  },
  "dependencies": {
    "expo": "^55.0.10-canary-20260328-2049187"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3"
  }
}
