{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "start": "EXPO_NO_TELEMETRY=1 CI=1 expo start --web --port 3000 --host lan",
    "start:native": "node ./scripts/metro-hint.cjs && expo start --go",
    "start:clear": "node ./scripts/metro-hint.cjs && expo start --clear --go",
    "start:sim": "expo start --localhost --clear --go",
    "start:tunnel": "node ./scripts/metro-hint.cjs && expo start --clear --go --tunnel",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "EXPO_NO_TELEMETRY=1 CI=1 expo start --web --port 3000 --host lan",
    "web:build": "expo export --platform web"
  },
  "dependencies": {
    "@expo-google-fonts/geist": "^0.4.2",
    "@expo-google-fonts/ibm-plex-mono": "^0.4.1",
    "@expo-google-fonts/ibm-plex-sans": "^0.4.1",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo-google-fonts/roboto": "^0.4.3",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/native": "^7.0.14",
    "expo": "^54.0.0",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "^56.0.4",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-media-library": "~18.2.1",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-speech": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-web-browser": "~15.0.10",
    "hls.js": "^1.5.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "node-abort-controller": "^3.1.1",
    "node-fetch": "^3.3.2",
    "patch-package": "^8.0.1",
    "readable-stream": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "private": true
}
